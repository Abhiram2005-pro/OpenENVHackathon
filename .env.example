# OpenEnv Data Pipeline Debugger — Environment Configuration
# Copy this file to .env and fill in your actual credentials

# ─── Required for inference.py ────────────────────────────────────────
# The base URL of your LLM API endpoint
API_BASE_URL=https://api.openai.com/v1

# The model name/identifier to use
# Examples: gpt-4, gpt-4-turbo, gpt-3.5-turbo
MODEL_NAME=gpt-4

# Hugging Face API token for authentication
# Get this from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Optional: If using OpenAI directly instead of Hugging Face endpoint
# OPENAI_API_KEY=sk_your_key_here

# ─── For Local Development ────────────────────────────────────────
# Leave these as-is for local testing
DEBUG=false
ENVIRONMENT=development
